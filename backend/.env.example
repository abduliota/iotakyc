# FastAPI Backend — copy to .env
PORT=8000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Government APIs
SPOST_API_KEY=
SPOST_BASE_URL=https://api.spost.com.sa
TKML_API_KEY=
TKML_BASE_URL=https://api.tkml.com.sa
ELM_API_KEY=
ELM_BASE_URL=https://natheer.elm.sa
